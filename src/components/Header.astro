---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";
import { ModeToggle } from "./ModeToggle";
---

<header>
  <nav class="flex flex-col items-center justify-center gap-2 mb-10">
    <ModeToggle client:load />

    <div class="flex flex-col gap-2 items-center pb-3">
      <h2 class="text-5xl capitalize font-bold">
        <a class="text-base-950 dark:text-base-200" href="/">{SITE_TITLE}</a>
      </h2>
    </div>

    <div class="flex gap-5">
      <HeaderLink href="https://github.com/ahkohd">Open Source</HeaderLink>
      <span>✦</span>
      <HeaderLink href="https://www.producthunt.com/@victor_aremu">Products</HeaderLink>
    </div>
  </nav>
</header>
